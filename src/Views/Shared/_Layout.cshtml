<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="utf-8" />
   <!-- <meta name="viewport" content="width=device-width, initial-scale=1.0"/> -->
   <title>Test Page - src</title>
   @*<link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />*@
   <!-- <link rel="stylesheet" href="src.styles.css"/> -->
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

   <style>
       .rounded-15 {
           border-radius: 15px !important;
       }
       .rounded-10 {
           border-radius: 10px;
       }

       .ml-250 {
           margin-left: 280px;
       }
        
       ul{
           list-style: none;
           padding: 0;
       }
       .nav-link {
           color: #6c757d;
       }

           .nav-link:hover {
               background-color: #f9fafb;
           }

           .nav-link.active {
               background-color: #eff6ff;
               color: #2563eb;
           }

       .footer-item:hover {
           background-color: #f9fafb;
       }

       .table {
           border-collapse: separate;
           border-spacing: 0;
       }

       .table thead tr:first-child th:first-child {
           border-top-left-radius: 15px;
       }

       .table thead tr:first-child th:last-child {
           border-top-right-radius: 15px;
       }

       .table tbody tr:last-child td:first-child {
           border-bottom-left-radius: 15px;
       }

       .table tbody tr:last-child td:last-child {
           border-bottom-right-radius: 15px;
       }
       .bg-green-100 {
           background-color: #dcfce7; /* Tailwind green-100 */
       }
       .bg-green-600 {
           background-color: #16a34a; /* Tailwind green-600 */
       }
       .text-green-700 {
           color: #15803d; /* Tailwind green-700 */
       }
       .bg-green-450 {
           background-color:#38d672; /* Tailwind green-200 */
       }
       .text-green-450 {
           color:#38d672;
       }

       .bg-yellow-100 {
           background-color: #fef9c3; /* Tailwind yellow-100 */
       }
       .text-yellow-600 {
           color: #ca8a04; /* Tailwind yellow-600 */
       }
       .bg-red-100 {
           background-color: #fee2e2; /* Tailwind red-100 */
       }
       .text-red-600 {
           color: #dc2626; /* Tailwind red-600 */
       }
       .bg-purple-100 {
           background-color: #f3e8ff; /* Tailwind purple-100 */
       }
       .text-purple-700 {
           color: #7e22ce; /* Tailwind purple-700 */
       }
       .bg-purple-500 {
           background-color: #A855F7; /* Tailwind default purple-500 */
       }
       .bg-orange-100 {
           background-color: #ffedd5; /* Tailwind orange-100 */
       }
       .text-orange-700 {
           color: #c2410c; /* Tailwind orange-700 */
       }
       .bg-orange-500 {
           background-color: #F97316; /* Tailwind default orange-500 */
       }

       .bg-gray-100 {
           background-color: #f3f4f6; /* Tailwind gray-100 */
       }
       .text-gray-700 {
           color: #374151; /* Tailwind gray-700 */
       }
       .bg-blue-100 {
           background-color: #dbeafe; /* Tailwind's blue-100 */
       }
       .text-blue-700 {
           color: #1d4ed8; /* Tailwind's blue-700 */
       }
       .bg-blue-500 {
           background-color: #3B82F6; /* Tailwind default blue-500 */
       }
        a{
            text-decoration: none;
            
        }
        .w-30px{
            width: 40px;
        } 
       .h-30px{
           height: 40px;
       }
       .w-65 {
           width: 65%;
       }

       .w-15 {
           width: 15%;
       }
   </style>
</head>
<body>
   <div>
       <div class="d-flex">

           <!-- Sidebar -->
           <nav class="col-md-3 col-lg-2 d-flex flex-column bg-white vh-100 border-end position-fixed" id="sticky-sidebar">

               <!-- Header -->
               <div class="text-center border-bottom py-3">
                   <h4>E-Commerce Admin</h4>
               </div>

               <!-- Navigation -->
               <ul class="nav flex-column align-items-center w-100 p-3">
                   <li class="nav-item w-100 p-1">
						<a class="nav-link rounded-15 py-3" href="/Dashboard/Index">
							<i class="bi bi-columns-gap h5"></i>
							<span class="ms-2">Dashboard</span>
						</a>
				   </li>
                   <li class="nav-item w-100 p-1">
						<a class="nav-link rounded-15 py-3" href="/Products/Index">
							<i class="bi bi-box-seam h5"></i>
							<span class="ms-2">Products</span>
						</a>
					</li>
                   <li class="nav-item w-100 p-1">
						<a class="nav-link rounded-15 py-3" href="/Orders/Index">
							<i class="bi bi-cart h5"></i>
							<span class="ms-2">Orders</span>
						</a>
					</li>
                   <li class="nav-item w-100 p-1">
						<a class="nav-link rounded-15 py-3" href="/Customers/Index">
							<i class="bi bi-people h5"></i>
							<span class="ms-2">Customers</span>
						</a>
				   </li>
                   <li class="nav-item w-100 p-1">
						<a class="nav-link rounded-15 py-3" href="/UserManagement/Index">
							<i class="bi bi-person-gear h5"></i>
							<span class="ms-2">User Management</span>
						</a>
					</li>
               </ul>

               <!-- Footer -->
               <div class="mt-auto w-100 d-flex flex-column align-items-center border-top h-auto justify-content-center p-3">
                   <div class="w-100 my-1 p-3 rounded-15 footer-item">
						<i class="bi bi-gear h5"></i>
						<span class="ms-2">Settings</span>
					</div>
                   <div class="w-100 my-1 p-3 rounded-15 footer-item">
						<i class="bi bi-box-arrow-right h5"></i>
						<span class="ms-2">Logout</span>
					</div>
               </div>

           </nav>

           <!-- Main Content -->
           <main class="col-md-9 col-lg-10 ml-250 p-3 bg-light">
               <div class="p-3 rounded-15 ">
                   @RenderBody()
               </div>
           </main>

       </div>
   </div>

   <script>
       document.querySelectorAll('.nav-link').forEach(link => {

           link.addEventListener('click', function () {

               document.querySelectorAll('.nav-link').forEach(item =>
                   item.classList.remove('active')
               );

               this.classList.add('active');

           });
       });
   </script>

   @*<script src="~/lib/jquery/dist/jquery.min.js"></script>*@
   @*<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>*@
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <!-- Popper.js -->
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
    <!-- Bootstrap JS -->
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.min.js"></script>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>			
   <script src="~/js/site.js" asp-append-version="true"></script>
   @await RenderSectionAsync("Scripts", required: false)
</body>
</html>